## -------------------------- 6) Clonal scatter ----------------------------- ##
plot_scatter <- function(seurat_obj, x_id, y_id, clone_call = "CTnt") {
  stopifnot(x_id %in% samples_all, y_id %in% samples_all)

  clonalScatter(
    seurat_obj,
    cloneCall = clone_call,
    x.axis    = x_id,
    y.axis    = y_id,
    dot.size  = "total",
    graph     = "count",
    palette   = "viridis"
  )
}

p_scatter_pair1 <- plot_scatter(data, "P5C", "FU1C", clone_call = "CTnt")
p_scatter_pair2 <- plot_scatter(data, "P9C", "FU2C", clone_call = "CTnt")
p_scatter_pair3 <- plot_scatter(data, "P1C", "FU3C", clone_call = "CTnt")
p_scatter_pair4 <- plot_scatter(data, "P23C", "FU4C", clone_call = "CTnt")
print(p_scatter_pair1)
print(p_scatter_pair2)
print(p_scatter_pair3)
print(p_scatter_pair4)

## ---------- 7) Combine samples into timepoints (before vs 1y post) -------- ##
# Combine SAMPLE_ID into a new variable for clonalScatter
data$SAMPLE_ID_combined <- dplyr::case_when(
  data$SAMPLE_ID %in% c("P5C", "P9C","P1C", "P23C")   ~ "at_diagnosed",
  data$SAMPLE_ID %in% c("FU1C", "FU2C","FU3C", "FU4C") ~ "one_year_post_diagnosed",
  TRUE                                  ~ as.character(data$SAMPLE_ID)
)

print(table(data$SAMPLE_ID_combined))

Idents(data) <- "SAMPLE_ID_combined"

p_scatter_timepoint <- clonalScatter(
  data,
  cloneCall = "CTnt",
  x.axis    = "at_diagnosed",
  y.axis    = "one_year_post_diagnosed",
  dot.size  = "total",
  graph     = "count",
  palette   = "viridis"
)

print(p_scatter_timepoint)

