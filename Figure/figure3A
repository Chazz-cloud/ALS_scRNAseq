})

## ----------------------------- 1) Load data ------------------------------ ##
obj_path <- "data.RDS"
data <- readRDS(obj_path)

# Quick check
print(table(data$GROUP, data$SAMPLE_ID))

# Convenience: all sample IDs present
samples_all <- sort(unique(as.character(data$SAMPLE_ID)))
message("Samples in object: ", paste(samples_all, collapse = ", "))

## ------------------------- 2) Define comparisons ------------------------- ##
pair1 <- c("P5C", "FU1C")
pair2 <- c("P9C", "FU2C")
pair3 <- c("P1C", "FU3C")
pair4 <- c("P23C", "FU4C")
stopifnot(all(pair1 %in% samples_all), all(pair2 %in% samples_all), all(pair3 %in% samples_all), all(pair4 %in% samples_all))
## -------------------- 3) Alluvial: top N clones (CTnt) ------------------- ##
p_top10_pair1 <- clonalCompare(
  data,
  samples    = pair1,
  top.clones = 10,
  cloneCall  = "CTnt",
  graph      = "alluvial",
  palette    = "viridis"
) +
  scale_x_discrete(limits = pair1) +
  theme(legend.text = element_text(size = 7))

