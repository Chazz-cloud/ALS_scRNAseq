# =========================
# 4. Extract metadata
# =========================

score_df <- data_shared_CD4_selected@meta.data

# =========================
# 5. Compare CSF vs Blood
# =========================
# assumes:
# TISSUE column contains "CSF" and "PBMC"
# modify if your labels differ

library(ggplot2)
library(dplyr)
library(rstatix)

score_columns <- grep("_Score1$", colnames(score_df), value = TRUE)


# =========================
# 6: summary table
# =========================

summary_table <- bind_rows(
  lapply(score_columns, function(score){
    
    test <- wilcox_test(
      score_df,
      as.formula(paste(score, "~ TISSUE"))
    )
    
    medians <- score_df %>%
      group_by(TISSUE) %>%
      summarise(
        median = median(.data[[score]], na.rm = TRUE)
      )
    
    data.frame(
      module = score,
      p_value = test$p,
      CSF_median = medians$median[medians$TISSUE == "CSF"],
      Blood_median = medians$median[medians$TISSUE == "PBMC"]
    )
  })
)

summary_table


# =========================
# Create clonotype-level CSF vs PBMC module score table
# =========================

clone_scores <- score_df %>%
  filter(
    !is.na(CTstrict),
    TISSUE %in% c("CSF", "PBMC")
  ) %>%
  group_by(CTstrict, TISSUE) %>%
  summarise(
    across(
      all_of(score_columns),
      ~ median(.x, na.rm = TRUE)
    ),
    n_cells = n(),
    .groups = "drop"
  )

clone_scores_wide <- clone_scores %>%
  pivot_wider(
    names_from = TISSUE,
    values_from = c(all_of(score_columns), n_cells),
    names_sep = "_"
  )

for(score in score_columns){
  clone_scores_wide[[paste0("Delta_", score)]] <-
    clone_scores_wide[[paste0(score, "_CSF")]] -
    clone_scores_wide[[paste0(score, "_PBMC")]]
}

# ==========================================
# 7. Convert to long format for plotting
# ==========================================

delta_df <- clone_scores_wide %>%
  
  select(
    CTstrict,
    starts_with("Delta_")
  ) %>%
  
  pivot_longer(
    cols = starts_with("Delta_"),
    names_to = "Module",
    values_to = "Delta_score"
  )

# clean names
delta_df$Module <- gsub("Delta_", "", delta_df$Module)
delta_df$Module <- gsub("_Score1", "", delta_df$Module)

# =========================================
###############################################
# ==========================================
# Median Δ score for each module
# ==========================================

delta_summary <- delta_df %>%
  
  group_by(Module) %>%
  
  summarise(
    median_delta = median(Delta_score, na.rm = TRUE),
    mean_delta   = mean(Delta_score, na.rm = TRUE),
    sd_delta     = sd(Delta_score, na.rm = TRUE),
    n_clonotypes = n()
  ) %>%
  
  arrange(median_delta)

delta_summary

# ==========================================
# Paired Wilcoxon test for each module
# ==========================================

delta_stats <- delta_df %>%
  
  group_by(Module) %>%
  
  wilcox_test(
    Delta_score ~ 1,
    mu = 0
  ) %>%
  
  select(Module, p)

# merge with delta values
delta_summary_final <- left_join(
  delta_summary,
  delta_stats,
  by = "Module"
)

delta_summary_final
####################### Plot #############################################

# ==========================================
# 1. Calculate module direction
# ==========================================

module_direction <- delta_df %>%
  
  group_by(Module) %>%
  summarise(
    median_delta = median(Delta_score, na.rm = TRUE)
  ) %>%
  
  mutate(
    Direction = case_when(
      median_delta > 0 ~ "Higher in CSF",
      median_delta < 0 ~ "Higher in Blood",
      TRUE ~ "No median difference"
    )
  )



# ==========================================
# 2. Order modules by median Δ score
# ==========================================

pvals <- delta_df %>%
  group_by(Module) %>%
  wilcox_test(Delta_score ~ 1, mu = 0) %>%
  mutate(
    p_label = ifelse(
      p < 0.001,
      paste0("p=", format(p, scientific = TRUE, digits = 2)),
      paste0("p=", signif(p, 2))
    )
  )

pvals_y <- delta_df %>%
  group_by(Module) %>%
  summarise(
    y = max(Delta_score, na.rm = TRUE) + 0.15,
    .groups = "drop"
  )

pvals <- left_join(pvals, pvals_y, by = "Module")



module_order <- module_direction %>%
  arrange(desc(median_delta)) %>%
  pull(Module)

delta_df$Module <- factor(
  delta_df$Module,
  levels = module_order
)

pvals$Module <- factor(
  pvals$Module,
  levels = module_order
)

module_direction$Module <- factor(
  module_direction$Module,
  levels = module_order
)


