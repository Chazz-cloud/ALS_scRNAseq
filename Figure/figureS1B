############################################################
## 14. Statistical comparison: module score in expanded vs non-expanded
############################################################

wilcox_results <- lapply(score_cols, function(score_col) {
  
  df <- data@meta.data %>%
    select(clonal_expansion, all_of(score_col)) %>%
    filter(!is.na(.data[[score_col]]))
  
  test <- wilcox.test(
    df[[score_col]] ~ df$clonal_expansion
  )
  
  data.frame(
    module = score_col,
    p_value = test$p.value,
    mean_expanded = mean(
      df[[score_col]][df$clonal_expansion == "Expanded"],
      na.rm = TRUE
    ),
    mean_nonexpanded = mean(
      df[[score_col]][df$clonal_expansion == "Non-expanded"],
      na.rm = TRUE
    )
  )
})

wilcox_results_df <- bind_rows(wilcox_results) %>%
  mutate(
    p_adj_BH = p.adjust(p_value, method = "BH")
  )

wilcox_results_df

