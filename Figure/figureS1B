############################################################
## 3. Check genes present in object
############################################################

module_gene_check <- lapply(names(module_list), function(mod) {
  
  genes <- module_list[[mod]]
  genes_present <- genes[genes %in% rownames(data)]
  genes_missing <- genes[!genes %in% rownames(data)]
  
  data.frame(
    module = mod,
    n_input = length(genes),
    n_present = length(genes_present),
    n_missing = length(genes_missing),
    missing_genes = paste(genes_missing, collapse = "; ")
  )
})

