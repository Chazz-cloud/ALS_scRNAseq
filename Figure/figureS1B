  row.names = FALSE
)

############################################################
## 4. Add module scores
## This does not change UMAP or clustering
############################################################

for (mod in names(module_list)) {
  
  genes_use <- module_list[[mod]]
  genes_use <- genes_use[genes_use %in% rownames(data)]
  
  if (length(genes_use) >= 3) {
    
    data <- AddModuleScore(
      object = data,
      features = list(genes_use),
      name = paste0(mod, "_Score")
    )
    
    old_name <- paste0(mod, "_Score1")
    new_name <- paste0(mod, "_Score")
    
    colnames(data@meta.data)[
      colnames(data@meta.data) == old_name
    ] <- new_name
  }
}

############################################################
## 5. Define clonal expansion
## Skip this if clone_size_sample and clonal_expansion already exist
############################################################

if (!all(c("clone_size_sample", "clonal_expansion") %in% colnames(data@meta.data))) {
  
  meta <- data@meta.data %>%
    rownames_to_column("cell_id")
  
  clone_size_df <- meta %>%
    filter(!is.na(CTstrict), CTstrict != "") %>%
    count(SAMPLE_ID, CTstrict, name = "clone_size_sample_new")
  
  meta <- meta %>%
    left_join(
      clone_size_df,
      by = c("SAMPLE_ID", "CTstrict")
    ) %>%
    mutate(
      clone_size_sample = ifelse(
        is.na(clone_size_sample_new),
        0,
        clone_size_sample_new
      ),
      clonal_expansion = ifelse(
        clone_size_sample >= 2,
        "Expanded",
        "Non-expanded"
      )
    ) %>%
    select(-clone_size_sample_new)
  
  data@meta.data <- meta %>%
    column_to_rownames("cell_id")
}

data$clonal_expansion <- factor(
  data$clonal_expansion,
  levels = c("Non-expanded", "Expanded")
)

table(data$clonal_expansion)
