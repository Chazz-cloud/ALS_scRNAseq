set.seed(1234)
## Setup##
suppressPackageStartupMessages({
  library(Seurat)
  library(dplyr)
  library(ggplot2)
  library(patchwork)
  library(harmony)
  library(broom)
  library(scRepertoire)
})

# Paths
base_dir <- "/…/Data anaysis/ "
setwd(base_dir)
rds_dir   <- file.path(base_dir)             
out_dir   <- file.path(base_dir, "output")   
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)

# Key params in one place
params <- list(
  nfeatures = 3000,
  dims      = 1:50,
  harmony_group_vars = c("orig.ident", "TISSUE"),
  cluster_res = c(0, 0.5, 1.0, 2.0, 3.0)
)

## -Sample sheet (metadata)  ##
# Create a clean sample sheet to drive loading + merging.
# REQUIRED columns:
#   - add_id: used as add.cell.id in merge()
#   - rds_file: RDS filename
#   - SAMPLE_ID / GROUP / TISSUE: desired metadata (will be enforced)

# Option A (recommended): maintain a CSV in repo
# sample_sheet <- read.csv("sample_sheet.csv", stringsAsFactors = FALSE)

stopifnot(all(file.exists(file.path(rds_dir, sample_sheet$rds_file))))

##  Helper functions ##
read_one_seurat <- function(rds_path, add_id, meta_row) {
  obj <- readRDS(rds_path)

  # enforce key metadata fields (overwrite if missing/inconsistent)
  obj$add_id    <- add_id
  obj$SAMPLE_ID <- meta_row$SAMPLE_ID
  obj$GROUP     <- meta_row$GROUP
  obj$TISSUE    <- meta_row$TISSUE

  return(obj)
}

merge_seurat_list <- function(obj_list, add_ids) {
  stopifnot(length(obj_list) == length(add_ids))
  merged <- merge(obj_list[[1]], y = obj_list[-1], add.cell.id = add_ids)
  return(merged)
}

save_pdf <- function(filename, plot, width = 12, height = 8) {
  pdf(file.path(out_dir, filename), width = width, height = height)
  print(plot)
  dev.off()
}

##  Load all samples + merge  ##
message("Loading objects...")
obj_list <- vector("list", nrow(sample_sheet))

for (i in seq_len(nrow(sample_sheet))) {
  rds_path <- file.path(rds_dir, sample_sheet$rds_file[i])
  obj_list[[i]] <- read_one_seurat(
    rds_path = rds_path,
    add_id   = sample_sheet$add_id[i],
    meta_row = sample_sheet[i, ]
  )
}

message("Merging objects...")
data_merged <- merge_seurat_list(obj_list, sample_sheet$add_id)

saveRDS(data_merged, file.path(out_dir, "Data_merged.RDS"))
rm(obj_list); gc()

##  QC summaries + remove doublets  ##
data <- readRDS(file.path(out_dir, "Data_merged.RDS"))

# Cell counts per sample x tissue (for sanity check)
tab <- table(data$orig.ident, data$TISSUE)
write.csv(tab, file.path(out_dir, "cell_counts_per_sample.csv"))

# QC plots
save_pdf("QC_nFeature_nCount.pdf",
         VlnPlot(data, features = c("nFeature_RNA", "nCount_RNA"), ncol = 1),
         width = 10, height = 10)

save_pdf("QC_percent_mt_hb_rp.pdf",
         VlnPlot(data, features = c("percent_mt", "percent_hb", "percent_rp"), ncol = 1),
         width = 10, height = 10)

# Remove predicted doublets (keep singlets)
if ("DF.name" %in% colnames(data@meta.data)) {
  Idents(data) <- "DF.name"
  data <- subset(data, subset = DF.name == "Singlet")
} else {
  warning("DF.name not found in metadata; skipping DoubletFinder filtering.")
}

saveRDS(data, file.path(out_dir, "data_merged_singlets.RDS"))

## Standard Seurat preprocessing ##
data <- readRDS(file.path(out_dir, "data_merged_singlets.RDS"))

# For Seurat v5: merge layers before normalization if needed
if ("layers" %in% slotNames(data[["RNA"]])) {
  data <- JoinLayers(data)
}

data <- NormalizeData(data)
data <- FindVariableFeatures(data, selection.method = "vst", nfeatures = params$nfeatures)
data <- ScaleData(data, features = VariableFeatures(data))
data <- RunPCA(data, features = VariableFeatures(data))

save_pdf("ElbowPlot.pdf", ElbowPlot(data, ndims = max(params$dims)), width = 8, height = 6)

# Non-integrated visualization (optional)
data <- RunUMAP(data, reduction = "pca", dims = params$dims)
data <- RunTSNE(data, reduction = "pca", dims = params$dims)

p_umap_raw <- DimPlot(data, reduction = "umap", group.by = "orig.ident", raster = FALSE) + NoLegend()
p_tsne_raw <- DimPlot(data, reduction = "tsne", group.by = "orig.ident", raster = FALSE) + NoLegend()
save_pdf("before_integration_umap_tsne.pdf", p_umap_raw + p_tsne_raw, width = 14, height = 6)

saveRDS(data, file.path(out_dir, "data_before_harmony.RDS"))

## Harmony integration ##
data <- readRDS(file.path(out_dir, "data_before_harmony.RDS"))

data <- RunHarmony(
  object = data,
  group.by.vars = params$harmony_group_vars,
  reduction = "pca",
  dims.use = params$dims,
  assay.use = "RNA"
)

data <- FindNeighbors(data, reduction = "harmony", dims = params$dims)
data <- FindClusters(data, resolution = params$cluster_res, verbose = TRUE)

data <- RunUMAP(data, reduction = "harmony", dims = params$dims)
data <- RunTSNE(data, reduction = "harmony", dims = params$dims)

p_umap <- DimPlot(data, reduction = "umap", group.by = "orig.ident", raster = FALSE) + NoLegend()
p_tsne <- DimPlot(data, reduction = "tsne", group.by = "orig.ident", raster = FALSE) + NoLegend()
save_pdf("after_integration_umap_tsne.pdf", p_umap + p_tsne, width = 14, height = 6)

p_split <- DimPlot(data, reduction = "tsne", group.by = "seurat_clusters",
                   split.by = "TISSUE", label = TRUE, repel = TRUE, raster = FALSE) + NoLegend()
save_pdf("after_integration_split_TISSUE.pdf", p_split, width = 18, height = 10)

saveRDS(data, file.path(out_dir, "data_after_harmony.RDS"))

##  Cluster stats (optional but useful) ##
data <- readRDS(file.path(out_dir, "data_after_harmony.RDS"))

# cluster size at active identity
cell_num  <- table(Idents(data))
cell_freq <- round(prop.table(cell_num), 4) * 100
cell_sum  <- rbind(freq_pct = cell_freq, n_cells = cell_num)
write.csv(cell_sum, file.path(out_dir, "cell_counts_freq_after_integrated.csv"))

##  Manual annotation from table  ##
# Annotation table should map cluster -> labels
# e.g., a CSV with columns: CLUSTER, CELL_TYPE
annot_path <- file.path(base_dir, "Anotations.csv")
if (file.exists(annot_path)) {
  annot <- read.csv(annot_path, sep = ";", header = TRUE, stringsAsFactors = FALSE)

  data$CELL_TYPE         <- annot[match(data$seurat_clusters, annot$CLUSTER), "CELL_TYPE"]

  p_ann <- DimPlot(data, reduction = "umap", group.by = "CELL_TYPE",
                   label = TRUE, repel = TRUE, raster = FALSE) + NoLegend()
  save_pdf("manual_annotation_umap.pdf", p_ann, width = 14, height = 7)

  saveRDS(data, file.path(out_dir, "data_after_harmony_annotated.RDS"))
} else {
  warning("Annotation file not found: ", annot_path)
}

##  TCR integration (optional)  ##
# This part assumes you already prepared contig_list_combined.RDS
tcr_path <- file.path(base_dir, "contig_list_combined.RDS")
if (file.exists(tcr_path)) {
  data <- readRDS(file.path(out_dir, "data_after_harmony_annotated.RDS"))

  contig_list <- readRDS(tcr_path)

  combined <- combineTCR(
    contig_list,
    samples = sample_sheet$add_id,
    removeNA = FALSE,
    removeMulti = FALSE,
    filterMulti = FALSE
  )

  # Attach GROUP information in the same order as sample IDs
  combined <- addVariable(
    combined,
    variable.name = "GROUP",
    variables = sample_sheet$GROUP
  )

  data <- combineExpression(
    combined, data,
    cloneCall = "strict",
    chain = "both",
    proportion = FALSE,
    cloneSize = c(Single = 1, Small = 5, Medium = 20, Large = 100, Hyperexpanded = 1000)
  )

  # Standardize cloneType factor levels for plotting
  data$cloneType <- factor(
    data$cloneSize,
    levels = c("Hyperexpanded (100 < X <= 1000)",
               "Large (20 < X <= 100)",
               "Medium (5 < X <= 20)",
               "Small (1 < X <= 5)",
               "Single (0 < X <= 1)")
  )

  saveRDS(data, file.path(out_dir, "data_after_harmony_annotated_TCR.RDS"))
} else {
  message("No TCR contig list found; skipping TCR integration.")
}

message("Done. Outputs saved to: ", out_dir)
